{{/* Fallback for MySQL <8 / MariaDB. Keep in sync with topQuery.tmpl — differs only in omitting query_sample_text from SELECT and using 5-column Scan. */}}
SELECT
    COALESCE(`schema_name`, ''),
    COALESCE(`digest`, ''),
    COALESCE(`digest_text`, ''),
    `count_star`,
    `sum_timer_wait`
FROM performance_schema.events_statements_summary_by_digest
WHERE `last_seen` >= NOW() - INTERVAL {{ .lookbackTime }} second
    AND ((`digest_text` NOT LIKE 'EXPLAIN %' AND `digest_text` NOT LIKE '/* otel-collector-ignore */%')
        OR `digest_text` IS NULL)
ORDER BY `count_star` DESC
LIMIT {{ .topNValue }}
