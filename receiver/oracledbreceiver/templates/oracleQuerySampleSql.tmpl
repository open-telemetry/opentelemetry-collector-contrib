/* otel-collector */ SELECT
S.ACTION,
S.MACHINE,
S.USERNAME,
S.SCHEMANAME,
S.SQL_ID,
S.SQL_CHILD_NUMBER,
RAWTOHEX(Q.CHILD_ADDRESS) AS CHILD_ADDRESS,
S.SID,
S.SERIAL#,
Q.SQL_FULLTEXT,
S.OSUSER,
S.PROCESS,
TO_CHAR(SYS_EXTRACT_UTC(FROM_TZ(CAST(S.LOGON_TIME AS TIMESTAMP), DBTIMEZONE)), 'YYYY-MM-DD"T"HH24:MI:SS"Z"') AS LOGON_TIME,
GREATEST(NVL((SYSDATE - S.LOGON_TIME) * 86400, 0), 0) AS SESSION_DURATION_SEC,
S.PORT,
S.PROGRAM,
S.MODULE,
S.STATUS,
S.STATE,
S.SERVICE_NAME,
NVL(C.NAME, '') AS DB_NAMESPACE,
Q.PLAN_HASH_VALUE,
P.OBJECT_ID AS PROCEDURE_ID,
GREATEST(NVL((SYSDATE - S.SQL_EXEC_START) * 86400, 0), 0) AS DURATION_SEC,
TO_CHAR(SYS_EXTRACT_UTC(FROM_TZ(CAST(S.SQL_EXEC_START AS TIMESTAMP), DBTIMEZONE)), 'YYYY-MM-DD"T"HH24:MI:SS"Z"') AS SQL_EXEC_START,
CASE WHEN S.TIME_REMAINING_MICRO IS NOT NULL
      THEN S.WAIT_CLASS END AS WAIT_CLASS,
CASE WHEN S.TIME_REMAINING_MICRO IS NOT NULL
      THEN S.EVENT END AS EVENT,
CASE WHEN S.TIME_REMAINING_MICRO IS NOT NULL
      THEN ROUND(S.WAIT_TIME_MICRO / 1000000, 4)
      ELSE 0 END AS WAIT_TIME_SEC,
CASE WHEN S.PLSQL_ENTRY_OBJECT_ID IS NOT NULL
      THEN P.OWNER || '.' || P.OBJECT_NAME
      END AS PROCEDURE_NAME, P.OBJECT_TYPE AS PROCEDURE_TYPE,
NVL(TO_CHAR(S.BLOCKING_SESSION), '') AS BLOCKING_SESSION,
NVL(TO_CHAR(S.FINAL_BLOCKING_SESSION), '') AS FINAL_BLOCKING_SESSION,
NVL(S.BLOCKING_SESSION_STATUS, '') AS BLOCKING_SESSION_STATUS,
NVL(S.SECONDS_IN_WAIT, 0) AS SECONDS_IN_WAIT,
CASE WHEN S.BLOCKING_SESSION IS NOT NULL
      THEN TO_CHAR(SYS_EXTRACT_UTC(SYSTIMESTAMP) - NUMTODSINTERVAL(S.SECONDS_IN_WAIT, 'SECOND'), 'YYYY-MM-DD"T"HH24:MI:SS"Z"')
      ELSE '' END AS BLOCKING_START_TIME,
NVL(LK.LOCK_TYPE, '') AS LOCK_TYPE,
NVL(LK.LOCK_MODE, '') AS LOCK_MODE,
NVL(O.OWNER, '') AS BLOCKED_OBJECT_OWNER,
NVL(O.OBJECT_NAME, '') AS BLOCKED_OBJECT_NAME
FROM V$SESSION S
  LEFT JOIN V$CONTAINERS C
    ON C.CON_ID = S.CON_ID
  LEFT JOIN (
    SELECT OWNER, OBJECT_ID, OBJECT_NAME, OBJECT_TYPE
    FROM   DBA_PROCEDURES
    WHERE  PROCEDURE_NAME IS NULL
  ) P
    ON P.OBJECT_ID = S.PLSQL_ENTRY_OBJECT_ID
  LEFT JOIN DBA_OBJECTS O
    ON O.OBJECT_ID = S.ROW_WAIT_OBJ#
  LEFT JOIN (
    SELECT SID,
           MIN(TYPE) AS LOCK_TYPE,
           DECODE(MIN(REQUEST),
                  2, 'ROW SHARE',
                  3, 'ROW EXCLUSIVE',
                  4, 'SHARE',
                  5, 'SHARE ROW EXCLUSIVE',
                  6, 'EXCLUSIVE',
                  'UNKNOWN') AS LOCK_MODE
    FROM   V$LOCK
    WHERE  REQUEST > 0
    GROUP BY SID
  ) LK
    ON LK.SID = S.SID
JOIN V$SQL Q
        ON Q.SQL_ID = COALESCE(S.SQL_ID, S.PREV_SQL_ID)
        AND Q.CHILD_NUMBER = COALESCE(S.SQL_CHILD_NUMBER, S.PREV_CHILD_NUMBER)
    WHERE S.TYPE = 'USER'
      AND S.SID != SYS_CONTEXT('USERENV', 'SID')
      AND (S.STATUS = 'ACTIVE'
       OR S.SID IN (SELECT DISTINCT BLOCKING_SESSION FROM V$SESSION WHERE BLOCKING_SESSION IS NOT NULL))
FETCH FIRST :1 ROWS ONLY
