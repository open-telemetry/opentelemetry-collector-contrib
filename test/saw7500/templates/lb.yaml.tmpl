apiVersion: v1
kind: Service
metadata:
  name: saw-7500-lb
  namespace: saw-7500
spec:
  selector:
    app: saw-7500-lb
  ports:
    - name: otlp-grpc
      port: 4317
      targetPort: otlp-grpc
    - name: metrics
      port: 8888
      targetPort: metrics
    - name: health
      port: 13133
      targetPort: health
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: saw-7500-lb
  namespace: saw-7500
spec:
  replicas: __LB_REPLICAS__
  minReadySeconds: 5
  strategy:
    type: RollingUpdate
    rollingUpdate:
      maxUnavailable: 0
      maxSurge: 1
  selector:
    matchLabels:
      app: saw-7500-lb
  template:
    metadata:
      labels:
        app: saw-7500-lb
    spec:
      serviceAccountName: saw-7500-lb
      terminationGracePeriodSeconds: 60
      containers:
        - name: main-collector
          image: __COLLECTOR_IMAGE__
          imagePullPolicy: IfNotPresent
          args:
            - --config=/etc/otelcol/collector.yaml
__LB_ENV__
          ports:
            - name: otlp-grpc
              containerPort: 4317
            - name: metrics
              containerPort: 8888
            - name: health
              containerPort: 13133
          volumeMounts:
            - name: config
              mountPath: /etc/otelcol
          readinessProbe:
            httpGet:
              path: /healthcheck
              port: health
            initialDelaySeconds: 5
            periodSeconds: 5
            timeoutSeconds: 1
            failureThreshold: 3
          livenessProbe:
            httpGet:
              path: /healthcheck
              port: health
            initialDelaySeconds: 5
            periodSeconds: 5
            timeoutSeconds: __LIVENESS_TIMEOUT_SECONDS__
            failureThreshold: __LIVENESS_FAILURE_THRESHOLD__
__LB_RESOURCES__
      volumes:
        - name: config
          configMap:
            name: saw-7500-lb-config
