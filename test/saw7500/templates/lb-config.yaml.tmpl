apiVersion: v1
kind: ConfigMap
metadata:
  name: saw-7500-lb-config
  namespace: saw-7500
data:
  collector.yaml: |
    receivers:
      otlp:
        protocols:
          grpc:
            endpoint: 0.0.0.0:4317
            max_recv_msg_size_mib: __RECEIVER_MAX_RECV_MSG_SIZE_MIB__

    extensions:
      health_check:
        endpoint: 0.0.0.0:13133

    exporters:
      loadbalancing:
        endpoint_health:
          enabled: __ENDPOINT_HEALTH_ENABLED__
          quarantine_duration: 30s
          reroute_on_failure: true
          max_reroute_attempts: 1
          active_probe:
            enabled: __ACTIVE_PROBE_ENABLED__
            type: tcp_connect
            interval: 5s
            timeout: 250ms
            jitter: 20%
            max_concurrency: 4
            fall: 2
            rise: 2
        central_queue:
          enabled: true
          max_compressed_bytes: __MAX_COMPRESSED_BYTES__
          payload_compression: zstd
          max_uncompressed_batch_bytes: __MAX_UNCOMPRESSED_BATCH_BYTES__
          max_inflight_uncompressed_bytes: __MAX_INFLIGHT_UNCOMPRESSED_BYTES__
          target_compressed_bytes: __TARGET_COMPRESSED_BYTES__
          max_batch_delay: 250ms
__NUM_CONSUMERS_CONFIG__
        log_routing:
          ignore_trace_id: true
        routing_key: service
        protocol:
          otlp:
            timeout: __BACKEND_TIMEOUT__
            tls:
              insecure: true
        resolver:
          k8s:
            service: saw-7500-backend.saw-7500.svc.cluster.local
            ports: [4317]
            timeout: __BACKEND_TIMEOUT__

    service:
      telemetry:
        logs:
          level: info
        metrics:
          readers:
            - pull:
                exporter:
                  prometheus:
                    host: 0.0.0.0
                    port: 8888
      extensions: [health_check]
      pipelines:
        logs:
          receivers: [otlp]
          exporters: [loadbalancing]
